{
  "name": "@edgecute/mcp",
  "version": "0.1.0",
  "description": "Edgecute Backtest MCP — build-time codegen + component library for traders building local apps in Cursor / Claude Code.",
  "type": "module",
  "bin": {
    "edgecute-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
