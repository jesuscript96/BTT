meta {
  name: Universe preview - filters are v2
  type: http
  seq: 12
}

post {
  url: {{baseUrl}}/v1/universe/preview
  body: json
  auth: inherit
}

body:json {
  {
    "filters": { "min_price": 1 }
  }
}

tests {
  test("501 not_implemented for filter-based universe", function () {
    expect(res.getStatus()).to.equal(501);
    expect(res.getBody().error.code).to.equal("not_implemented");
  });
}
