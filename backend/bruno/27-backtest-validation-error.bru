meta {
  name: Backtest run - schema validation error
  type: http
  seq: 27
}

post {
  url: {{baseUrl}}/v1/backtests
  body: json
  auth: inherit
}

body:json {
  {
    "universe": {
      "dataset_ref": "ds_123",
      "date_from": "2024-01-01",
      "date_to": "2024-01-31"
    },
    "strategy": {
      "name": "VWAP fade short",
      "bias": "short",
      "apply_day": "gap_day",
      "entry_logic": {
        "timeframe": "1m",
        "root_condition": {
          "type": "group",
          "operator": "AND",
          "conditions": [
            {
              "type": "indicator_comparison",
              "source": { "name": "Bar Close" },
              "comparator": "CROSSES_BELOW",
              "target": { "name": "VWAP" }
            }
          ]
        }
      },
      "risk_management": {
        "use_hard_stop": true,
        "hard_stop": { "type": "Percentage", "value": 3.0 }
      }
    },
    "execution": { "fee_type": "PER_SHARE" }
  }
}

tests {
  test("422 validation_error with field details (bad fee_type enum)", function () {
    expect(res.getStatus()).to.equal(422);
    const err = res.getBody().error;
    expect(err.code).to.equal("validation_error");
    expect(err.details.fields).to.be.an("array").that.is.not.empty;
    expect(err.details.fields.some((f) => f.path.includes("fee_type"))).to.equal(true);
  });
}
