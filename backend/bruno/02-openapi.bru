tests {
  test("200 and valid OpenAPI envelope", function () {
    expect(res.getStatus()).to.equal(200);
    const body = res.getBody();
    expect(body.openapi).to.be.a("string");
    expect(body.info).to.be.an("object");
    expect(body.paths).to.have.property("/v1/health");
    expect(body.paths).to.have.property("/v1/backtests");
  });
}
