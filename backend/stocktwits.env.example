# ─── Integración Stocktwits (social) ─────────────────────────────────────────
# Copia estas claves a tu backend/.env (NUNCA commitees el .env con valores reales).
# Las llamadas a Stocktwits se hacen SOLO desde el backend con Basic Auth.

# Credenciales Basic Auth de la API oficial de Stocktwits (obligatorias en prod).
STOCKTWITS_API_KEY=your_stocktwits_api_key
STOCKTWITS_API_SECRET=your_stocktwits_api_secret

# Base URL del gateway (cambiar solo si Stocktwits migra de host).
# STOCKTWITS_BASE_URL=https://api-gw-prd.stocktwits.com

# ─── Defaults técnicos reversibles (opcionales) ──────────────────────────────
# Filtro anti-spam de la Zona de Debate.
# STOCKTWITS_MIN_LIKES=2
# STOCKTWITS_MAX_TICKERS=3
# Capitalización máxima (millones USD) del Radar de Momentum.
# STOCKTWITS_SMALL_CAP_MAX_M=2000
# TTLs de la caché SWR (minutos).
# STOCKTWITS_TTL_TRENDING_MIN=3
# STOCKTWITS_TTL_SENTIMENT_MIN=5
# STOCKTWITS_TTL_SUMMARY_MIN=10
# STOCKTWITS_TTL_STREAM_MIN=3
# STOCKTWITS_TTL_NEWSLETTER_MIN=30
